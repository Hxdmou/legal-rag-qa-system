# RAG 智能问答系统 - 环境变量配置示例

# 复制此文件为 .env 并根据实际情况修改配置
# cp .env.example .env

# ========================================================
# 【必填配置】LLM API 密钥 - 至少配置其中一项
# ========================================================

# 阿里云百炼 API Key (国内推荐，支持 qwen2.5 系列模型)
# 获取地址: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# OpenAI API Key (如需使用 OpenAI 模型，必填)
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI API 基础地址 (支持代理或兼容 API)
OPENAI_API_BASE=https://api.openai.com/v1

# ========================================================
# 【可选配置】模型参数
# ========================================================

# LLM 模型名称
# 阿里云百炼: qwen2.5-72b-instruct, qwen2.5-32b-instruct, qwen-turbo 等
# OpenAI: gpt-3.5-turbo, gpt-4, gpt-4o 等
LLM_MODEL_NAME=qwen2.5-72b-instruct

# 温度参数 (0-1, 越低越确定性)
LLM_TEMPERATURE=0.7

# 最大 Token 数
LLM_MAX_TOKENS=4096

# ========================================================
# 【可选配置】Embedding 模型
# ========================================================

# Embedding 模型
# 阿里云百炼: text-embedding-v2 (默认)
# OpenAI: text-embedding-3-small, text-embedding-3-large
EMBEDDING_MODEL=text-embedding-v2

# ========================================================
# 【可选配置】文档分割参数
# ========================================================

# 文档分块大小
CHUNK_SIZE=500

# 分块重叠大小
CHUNK_OVERLAP=50

# 检索返回文档数量
TOP_K=5

# ========================================================
# 【可选配置】向量数据库
# ========================================================

# 向量数据库类型 (支持: faiss, chroma, qdrant)
# 默认: faiss
VECTOR_DB_TYPE=faiss

# ========================================================
# 【可选配置】应用参数
# ========================================================

# 服务端口
PORT=7861

# 项目名称
PROJECT_NAME=RAG智能问答系统

# 版本号
VERSION=2.1.0

# 调试模式 (true/false)
DEBUG=false

# 最大文件大小限制 (MB)
MAX_FILE_SIZE=50

# 最大上传文件数量
MAX_UPLOAD_FILES=10

# 支持的文件类型
SUPPORTED_FILE_TYPES=["txt", "pdf", "xlsx", "xls", "docx", "doc"]

# ========================================================
# 【可选配置】日志参数
# ========================================================

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=./logs/app.log

# ========================================================
# 配置说明
# ========================================================
# 1. 阿里云百炼配置（国内推荐）:
#    - 获取 API Key: https://dashscope.aliyun.com/
#    - 设置 DASHSCOPE_API_KEY 即可使用
#    - 支持 qwen2.5 系列模型，性价比高

# 2. OpenAI 配置:
#    - 获取 API Key: https://platform.openai.com/api-keys
#    - 设置 OPENAI_API_KEY 和 OPENAI_API_BASE
#    - 支持 gpt-3.5-turbo, gpt-4 等模型

# 3. 推荐配置组合:
#    - DASHSCOPE_API_KEY + qwen2.5-72b-instruct（国内首选）
#    - OPENAI_API_KEY + gpt-4o（高质量首选）
