# RAG 智能问答系统 - 环境变量配置示例

# 复制此文件为 .env 并根据实际情况修改配置

# ==================== LLM 配置 ====================
# OpenAI API Key (如需使用 OpenAI 模型)
OPENAI_API_KEY=your-openai-api-key-here

# 智谱 API Key (如需使用智谱模型)
ZHIPU_API_KEY=your-zhipu-api-key-here

# 模型名称 (支持: gpt-3.5-turbo, gpt-4, glm-4, glm-3-turbo 等)
LLM_MODEL=gpt-3.5-turbo

# API 基础地址 (如需使用代理或本地模型)
# OPENAI_API_BASE=https://api.openai.com/v1
# ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4/

# ==================== Embedding 配置 ====================
# Embedding 模型选择
# 可选值: openai, text-embedding-3-small, text-embedding-3-large, 
#         sentence-transformers, all-MiniLM-L6-v2, m3e-base, bge-small-zh
EMBEDDING_MODEL=text-embedding-3-small

# 本地 Embedding 模型路径 (当使用本地模型时)
EMBEDDING_MODEL_PATH=

# ==================== 向量数据库配置 ====================
# FAISS 索引存储路径
FAISS_INDEX_PATH=./faiss_index

# 向量数据库类型 (支持: faiss, chroma, qdrant)
VECTOR_DB_TYPE=faiss

# Qdrant 配置 (当使用 Qdrant 时)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# Chroma 配置 (当使用 Chroma 时)
CHROMA_DB_PATH=./chroma_db

# ==================== 应用配置 ====================
# 服务端口
PORT=7861

# 调试模式
DEBUG=false

# 最大文档大小限制 (MB)
MAX_FILE_SIZE=50

# 对话历史保留数量
MAX_HISTORY_COUNT=50

# ==================== 日志配置 ====================
# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=./logs/app.log
