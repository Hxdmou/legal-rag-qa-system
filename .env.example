# RAG 智能问答系统 - 环境变量配置示例

# 复制此文件为 .env 并根据实际情况修改配置
# cp .env.example .env

# ========================================================
# 【必填配置】LLM API 密钥 - 至少配置其中一项
# ========================================================

# OpenAI API Key (如需使用 OpenAI 模型，必填)
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# 智谱 API Key (如需使用智谱模型，必填)
# 获取地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=your-zhipu-api-key-here

# ========================================================
# 【可选配置】模型参数
# ========================================================

# 模型名称 (支持: gpt-3.5-turbo, gpt-4, glm-4, glm-3-turbo 等)
# 默认: gpt-3.5-turbo
LLM_MODEL=gpt-3.5-turbo

# API 基础地址 (如需使用代理或本地模型)
# OpenAI 代理地址
# OPENAI_API_BASE=https://api.openai.com/v1
# 智谱 API 地址
# ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4/
# 本地 Ollama 地址 (使用本地模型时)
# OPENAI_API_BASE=http://localhost:11434/v1

# ========================================================
# 【必填配置】Embedding 模型
# ========================================================

# Embedding 模型选择
# 可选值: 
#   - openai (使用 OpenAI Embedding，需要 OPENAI_API_KEY)
#   - text-embedding-3-small (OpenAI 轻量模型)
#   - text-embedding-3-large (OpenAI 大型模型)
#   - sentence-transformers (开源模型)
#   - all-MiniLM-L6-v2 (轻量开源模型)
#   - m3e-base (中文开源模型)
#   - bge-small-zh (中文轻量模型)
# 默认: text-embedding-3-small
EMBEDDING_MODEL=text-embedding-3-small

# 本地 Embedding 模型路径 (当使用本地模型时，可选)
# EMBEDDING_MODEL_PATH=./models/

# ========================================================
# 【可选配置】向量数据库
# ========================================================

# 向量数据库类型 (支持: faiss, chroma, qdrant)
# 默认: faiss
VECTOR_DB_TYPE=faiss

# FAISS 索引存储路径
FAISS_INDEX_PATH=./faiss_index

# Qdrant 配置 (当使用 Qdrant 时)
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_API_KEY=your-qdrant-api-key

# Chroma 配置 (当使用 Chroma 时)
# CHROMA_DB_PATH=./chroma_db

# ========================================================
# 【可选配置】应用参数
# ========================================================

# 服务端口
PORT=7861

# 调试模式 (true/false)
DEBUG=false

# 最大文件大小限制 (MB)
MAX_FILE_SIZE=50

# 对话历史保留数量
MAX_HISTORY_COUNT=50

# ========================================================
# 【可选配置】日志参数
# ========================================================

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=./logs/app.log

# ========================================================
# 配置说明
# ========================================================
# 1. 开发环境建议:
#    - 使用 OpenAI gpt-3.5-turbo 进行快速测试
#    - 使用 all-MiniLM-L6-v2 作为 Embedding 模型

# 2. 生产环境建议:
#    - 根据业务需求选择合适的 LLM 模型
#    - 考虑使用本地模型以降低成本
#    - 配置日志轮转和监控

# 3. 本地运行建议:
#    - 安装 Ollama: https://ollama.com/
#    - 拉取模型: ollama pull llama3
#    - 配置: LLM_MODEL=llama3, OPENAI_API_BASE=http://localhost:11434/v1
